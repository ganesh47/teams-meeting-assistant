# Join runtime controls
TEAMS_HEADLESS=1
TEAMS_AUTO_JOIN=0
TEAMS_MUTE_MICROPHONE=1
TEAMS_DISABLE_CAMERA=1
TEAMS_DISPLAY_NAME=Meeting Assistant
TEAMS_PROFILE_DIR=.profiles/teams-personal

# Audio pipeline controls
TEAMS_AUDIO_MODE=system_loopback
TEAMS_AUDIO_FIXTURE_PATH=
TEAMS_AUDIO_SAMPLE_RATE=16000
TEAMS_AUDIO_CHANNELS=1
TEAMS_AUDIO_CHUNK_MS=1000

# Transcription backend controls
TEAMS_WHISPER_MODEL=base
